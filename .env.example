# Copy this file to .env.local and fill in the values.
# Supabase: Dashboard → Project Settings → API (or Data API / API Keys tabs)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Optional — instant email notification when a review is submitted.
# Sign up free at https://resend.com to get RESEND_API_KEY.
# Leave these blank to skip email notifications entirely.
RESEND_API_KEY=
NOTIFY_EMAIL=your-office-admin@example.com
NOTIFY_FROM_EMAIL=CSSA Reviews <onboarding@resend.dev>
